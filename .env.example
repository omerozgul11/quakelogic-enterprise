APP_NAME="QuakeLogic Proposals"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_PORT=8080

# App-switcher (hub) — URLs of the separate company apps.
SHIPMENTS_APP_URL=https://shipments.quakelogic.net
PROJECT_MANAGER_APP_URL=https://projectmanager.quakelogic.net

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=quakelogic_enterprise
DB_USERNAME=quakelogic
DB_PASSWORD=quakelogic_password
DB_ROOT_PASSWORD=root_password

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
QUEUE_FAILED_TABLE=failed_jobs

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=ql_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@quakelogic.net"
MAIL_FROM_NAME="${APP_NAME}"

# S3 / MinIO
FILESYSTEM_CLOUD=s3
AWS_ACCESS_KEY_ID=quakelogic-minio
AWS_SECRET_ACCESS_KEY=quakelogic-minio-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=quakelogic-enterprise
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/quakelogic-enterprise

# Meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey
SCOUT_DRIVER=meilisearch

# AI Providers (leave empty to use fake provider for local demo)
AI_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Google Gemini (Google AI Studio). Free-tier key from https://aistudio.google.com/apikey
# To use Gemini: set AI_PROVIDER=gemini and GEMINI_API_KEY=... (free tier trains on your data).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
LOCAL_LLM_HOST=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# SAM.gov Integration
SAM_GOV_API_KEY=
SAM_GOV_BASE_URL=https://api.sam.gov
SAM_GOV_SYNC_ENABLED=false

# BidPrime Integration
BIDPRIME_API_KEY=
BIDPRIME_BASE_URL=https://api.bidprime.com
BIDPRIME_SYNC_ENABLED=false

# Google OAuth / Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Microsoft OAuth / Graph
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"

# Notifications
NOTIFICATION_CHANNELS=database,mail

# Commission
COMMISSION_CALCULATION_ENABLED=true

# Security
FORTIFY_PASSWORD_MIN=12
MFA_ENABLED=false

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

# Shipments — UPS Tracking (fake client used until enabled + credentialed)
UPS_SYNC_ENABLED=false
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_BASE_URL=https://onlinetools.ups.com

# Quantum View auto-ingest (set up the product + an outbound subscription on the UPS account first)
UPS_QV_ENABLED=false
UPS_QV_SUBSCRIPTION=
UPS_QV_ORGANIZATION_ID=1

# Shipments — J.B. Hunt 360 freight tracking (fake client in dev until enabled + credentialed;
# stays manual in production until set). Get credentials at developer.jbhunt.com.
JBHUNT_SYNC_ENABLED=false
JBHUNT_CLIENT_ID=
JBHUNT_CLIENT_SECRET=
JBHUNT_BASE_URL=https://api.jbhunt.com
# Optional — set to match the J.B. Hunt 360 API docs once issued credentials:
JBHUNT_TOKEN_URL=
JBHUNT_SCOPE=
JBHUNT_SUBSCRIPTION_KEY=
JBHUNT_TRACK_PATH=/shipment-tracking/v1/shipments/{tracking}
